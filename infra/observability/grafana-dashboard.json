{
  "title": "Gigmann Executive Cockpit — API",
  "uid": "gigmann-api",
  "schemaVersion": 39,
  "tags": ["gigmann"],
  "timezone": "utc",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "title": "Request rate (req/s by route)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by (route) (rate(http_requests_total[5m]))", "legendFormat": "{{route}}" }
      ]
    },
    {
      "id": 2, "title": "Error rate (5xx %)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "100 * sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)", "legendFormat": "5xx %" }
      ]
    },
    {
      "id": 3, "title": "Latency p95 (s by route)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{route}}" }
      ]
    }
  ]
}
