# =============================================================================
# .env.example — Gigmann Executive Cockpit (frontend / Vite + React SPA)
# =============================================================================
# TEMPLATE ONLY — contains no real values and IS committed (the root .gitignore
# un-ignores ".env.example"). Copy it to start:
#     cp .env.example .env.local      # personal local overrides (gitignored)
#
# HOW VITE LOADS ENV FILES (increasing priority):
#     .env  →  .env.[mode]  →  .env.local  →  .env.[mode].local
# "mode" is "development" for `npm run dev` and "production" for `npm run build`.
# NOTE: a file named "production.env" is NOT loaded by Vite — it must be
# ".env.production". Same for ".env.example" vs ".example.env".
#
# ⚠️  EVERYTHING HERE IS PUBLIC. Vite exposes only VITE_-prefixed variables to
# the browser and INLINES them into the JavaScript bundle at build time, so any
# visitor can read them with devtools. NEVER put a secret in a VITE_ var.
# =============================================================================


# REQUIRED for any deployment where the API is on a different origin than the
# SPA (which is the case on Vercel: SPA on Vercel, Go API on Render).
# Origin of the backend API — no trailing slash.
#     local dev  : http://localhost:8080
#     production : https://gigmann-api.onrender.com
# If left empty the client falls back to "/" (same-origin). On Vercel that would
# send every API call to the Vercel domain, which has no backend → all requests
# 404. Also used to derive the WebSocket URL for live updates.
VITE_API_BASE_URL=

# OPTIONAL. Browser error tracking. A frontend Sentry DSN is public by design.
# Empty = the Sentry SDK is never downloaded (it is a lazily-imported chunk).
VITE_SENTRY_DSN=
