# Copy to .env for local development. NEVER commit real secrets.
# Loaded and validated at startup by internal/config.

# HTTP server
APP_ENV=development          # development | staging | production
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
LOG_LEVEL=debug              # debug | info | warn | error

# Database (Postgres 16 + pgvector)
DATABASE_URL=postgres://gigmann:gigmann@localhost:5432/gigmann?sslmode=disable

# Redis (cache + websocket pub/sub fan-out)
REDIS_URL=redis://localhost:6379/0

# Auth (custom JWT) — generate real keys per environment, store as secrets
JWT_PRIVATE_KEY_PATH=./secrets/jwt_ed25519.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_ed25519.pub
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Anthropic Claude (intelligence service)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
