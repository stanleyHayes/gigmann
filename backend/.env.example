# Copy to .env for local development. NEVER commit real secrets.
# This lists exactly the variables internal/config reads (and validates at boot).
# Everything except JWT_SECRET (outside development) is optional — the app falls
# back to in-memory repos + the deterministic local narrator/embedder when unset.

# ---- HTTP server ----
APP_ENV=development            # development | staging | production (validated)
HTTP_PORT=8080
LOG_LEVEL=info                 # debug | info | warn | error

# ---- Auth ----
# Required outside development; must be >=32 chars and not the dev placeholder
# (fails fast at boot otherwise). Development falls back to an insecure default.
JWT_SECRET=
DEMO_PASSWORD=                 # optional — seed login password (defaults to a dev value)

# ---- CORS / proxy ----
CORS_ALLOWED_ORIGINS=http://localhost:5173   # comma-separated; '*' rejected outside dev
TRUST_PROXY=false             # set true behind a TLS-terminating proxy (Render) for real client IPs

# ---- Persistence (optional: unset => in-memory demo from the synthetic network) ----
DATABASE_URL=                 # e.g. postgres://gigmann:gigmann@localhost:5432/gigmann?sslmode=disable
REDIS_URL=                    # e.g. redis://localhost:6379/0

# ---- Anthropic Claude (optional: unset => deterministic local narrator) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Voyage embeddings for NL facility search (optional: unset => local lexical embedder) ----
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5-lite

# ---- Web Push (optional: unset => push is a no-op) ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=                # e.g. mailto:ops@gigmann.health

# ---- Observability (optional: unset => no-op) ----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=          # base OTLP endpoint (traces derived if the specific one is unset)
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=   # explicit traces endpoint (overrides the base)

# ---- Feature flags (default on) ----
FEATURE_AI_NARRATION=true     # false => force the local narrator even if ANTHROPIC_API_KEY is set
FEATURE_FACILITY_SEARCH=true  # false => NL facility search returns no matches
